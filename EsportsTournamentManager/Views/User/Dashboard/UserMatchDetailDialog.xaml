<Window x:Class="EsportsTournamentManager.Views.User.UserMatchDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Thống kê Trận đấu" Height="620" Width="1020"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- Hyperlink Button Style -->
        <Style x:Key="HyperlinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#6366F1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}" TextDecorations="Underline" Foreground="{TemplateBinding Foreground}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#818CF8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Stats Grid Style (Read Only) -->
        <Style x:Key="StatDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="RowBackground" Value="#111827"/>
            <Setter Property="AlternatingRowBackground" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeight" Value="34"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1E293B"/>
                        <Setter Property="Foreground" Value="#9CA3AF"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#334155"/>
                      <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="8,0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter SnapsToDevicePixels="True"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1.5">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Scoreboard Summary -->
                <RowDefinition Height="*"/>    <!-- Tabs Area -->
                <RowDefinition Height="Auto"/> <!-- Close Button -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🏆" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="CHI TIẾT TRẬN ĐẤU" Foreground="#F9FAFB" FontSize="18" FontWeight="Black" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Background="Transparent" Foreground="#9CA3AF" FontSize="18" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="CloseButton_Click"/>
            </Grid>

            <!-- Scoreboard Summary -->
            <Border Grid.Row="1" Background="#111827" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.5*"/> <!-- Team 1 Link -->
                        <ColumnDefinition Width="1.5*"/> <!-- Score -->
                        <ColumnDefinition Width="2.5*"/> <!-- Team 2 Link -->
                        <ColumnDefinition Width="2.5*"/> <!-- MVP Info -->
                    </Grid.ColumnDefinitions>

                    <!-- Team 1 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse Width="24" Height="24" Fill="#6366F1" Margin="0,0,12,0"/>
                        <Button x:Name="BtnTeam1Link" Content="Team 1" Style="{StaticResource HyperlinkButton}" FontSize="15" FontWeight="Bold" Click="Team1Link_Click" MaxWidth="160"/>
                    </StackPanel>

                    <!-- Score -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtTeam1Score" Text="0" Foreground="#F9FAFB" FontSize="26" FontWeight="Black"/>
                            <TextBlock Text=" - " Foreground="#9CA3AF" FontSize="20" FontWeight="Black" Margin="8,0"/>
                            <TextBlock x:Name="TxtTeam2Score" Text="0" Foreground="#F9FAFB" FontSize="26" FontWeight="Black"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtMatchFormat" Text="BO3" Foreground="#6B7280" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>

                    <!-- Team 2 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button x:Name="BtnTeam2Link" Content="Team 2" Style="{StaticResource HyperlinkButton}" FontSize="15" FontWeight="Bold" Click="Team2Link_Click" MaxWidth="160" Margin="0,0,12,0"/>
                        <Ellipse Width="24" Height="24" Fill="#EF4444"/>
                    </StackPanel>

                    <!-- MVP Info -->
                    <Border Grid.Column="3" BorderBrush="#1E293B" BorderThickness="1,0,0,0" Padding="20,0,0,0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="MVP TRẬN ĐẤU" Foreground="#9CA3AF" FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                            <Border Background="#1E1B4B" BorderBrush="#4F46E5" BorderThickness="1" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⭐" Margin="0,0,4,0" VerticalAlignment="Center" FontSize="10"/>
                                    <Button x:Name="BtnMatchMvpLink" Content="Chưa xác định" Style="{StaticResource HyperlinkButton}" Foreground="#818CF8" FontSize="12" FontWeight="Black" Click="PlayerLink_Click"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Tabs Area -->
            <TabControl x:Name="TabMatchDetails" Grid.Row="2" Background="Transparent" BorderThickness="0" Margin="0,0,0,20">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Foreground" Value="#9CA3AF"/>
                        <Setter Property="HeaderTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" 
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}" 
                                               Margin="16,8" FontSize="13" FontWeight="Bold"/>
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="Border" BorderBrush="#1E293B" BorderThickness="1,1,1,0" CornerRadius="6,6,0,0" Margin="0,0,6,0" Background="#111827">
                                        <ContentPresenter x:Name="ContentSite" ContentSource="Header"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                            <Setter TargetName="Border" Property="Background" Value="#1E293B"/>
                                            <Setter TargetName="Border" Property="BorderBrush" Value="#4F46E5"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="False">
                                            <Setter Property="Foreground" Value="#9CA3AF"/>
                                            <Setter TargetName="Border" Property="Opacity" Value="0.6"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- Tab 1: Tổng quan ván đấu -->
                <TabItem Header="TỔNG QUAN">
                    <Border Background="#111827" CornerRadius="0,8,8,8" Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="DANH SÁCH CÁC VÁN ĐẤU" Foreground="#9CA3AF" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                            
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="ItemsMapsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/> <!-- Map name -->
                                                        <ColumnDefinition Width="*"/> <!-- Score comparison -->
                                                        <ColumnDefinition Width="200"/> <!-- MVP of Map -->
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Map name -->
                                                    <TextBlock Grid.Column="0" Text="{Binding SelectedMapName}" Foreground="#F9FAFB" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>

                                                    <!-- Score comparison -->
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Team1RoundScore}" Foreground="#6366F1" FontSize="18" FontWeight="Black"/>
                                                        <TextBlock Text=" : " Foreground="#9CA3AF" FontSize="16" Margin="10,0"/>
                                                        <TextBlock Text="{Binding Team2RoundScore}" Foreground="#EF4444" FontSize="18" FontWeight="Black"/>
                                                    </StackPanel>

                                                    <!-- MVP of Map -->
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                        <TextBlock Text="👑 MVP: " Foreground="#F59E0B" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                                        <!-- Hyperlink to MVP -->
                                                        <Button Content="{Binding MVPlayer.InGameName}" Style="{StaticResource HyperlinkButton}" Foreground="#FFFFFF" FontSize="13" FontWeight="Bold" Tag="{Binding MVPlayer}" Click="PlayerLink_Click" Margin="5,0,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- Tab 2: Thống kê tuyển thủ -->
                <TabItem Header="THỐNG KÊ TUYỂN THỦ">
                    <Border Background="#111827" CornerRadius="0,8,8,8" Padding="15">
                        <Grid>
                            <!-- TabControl inside to switch between maps for player statistics -->
                            <TabControl x:Name="TabPlayerStatsMaps" Background="Transparent" BorderThickness="0">
                                <TabControl.Resources>
                                    <Style TargetType="TabItem">
                                        <Setter Property="Foreground" Value="#9CA3AF"/>
                                        <Setter Property="HeaderTemplate">
                                            <Setter.Value>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}" Margin="10,4" FontSize="11" FontWeight="Bold"/>
                                                </DataTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TabItem">
                                                    <Border x:Name="Border" BorderBrush="#334155" BorderThickness="1" CornerRadius="4" Margin="0,0,4,4" Background="#1E293B">
                                                        <ContentPresenter x:Name="ContentSite" ContentSource="Header"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Foreground" Value="#6366F1"/>
                                                            <Setter TargetName="Border" Property="Background" Value="#0F172A"/>
                                                            <Setter TargetName="Border" Property="BorderBrush" Value="#6366F1"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TabControl.Resources>
                                
                                <!-- Dynamic maps tabs containing side-by-side grids will be created programmatically -->
                            </TabControl>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- Tab 3: Chỉ số đối đầu -->
                <TabItem Header="MỤC TIÊU &amp; CHỈ SỐ">
                    <Border Background="#111827" CornerRadius="0,8,8,8" Padding="25">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="SO SÁNH HIỆU SUẤT TRUNG BÌNH" Foreground="#9CA3AF" FontSize="12" FontWeight="Bold" Margin="0,0,0,25"/>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel VerticalAlignment="Center">
                                    <!-- Avg Kills comparison -->
                                    <StackPanel Margin="0,0,0,25">
                                        <Grid Margin="0,0,0,5">
                                            <TextBlock x:Name="TxtT1Kills" Text="0 Kills" Foreground="#6366F1" FontWeight="Bold" FontSize="12"/>
                                            <TextBlock Text="Tổng mạng hạ gục" Foreground="#9CA3AF" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="TxtT2Kills" Text="0 Kills" Foreground="#EF4444" FontWeight="Bold" FontSize="12" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <Grid Height="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition x:Name="ColT1Kills" Width="1*"/>
                                                <ColumnDefinition x:Name="ColT2Kills" Width="1*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#6366F1" CornerRadius="5,0,0,5"/>
                                            <Border Grid.Column="1" Background="#EF4444" CornerRadius="0,5,5,0"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Avg Damage comparison -->
                                    <StackPanel Margin="0,0,0,25">
                                        <Grid Margin="0,0,0,5">
                                            <TextBlock x:Name="TxtT1Damage" Text="0 DMG" Foreground="#6366F1" FontWeight="Bold" FontSize="12"/>
                                            <TextBlock Text="Tổng sát thương gây ra" Foreground="#9CA3AF" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="TxtT2Damage" Text="0 DMG" Foreground="#EF4444" FontWeight="Bold" FontSize="12" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <Grid Height="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition x:Name="ColT1Damage" Width="1*"/>
                                                <ColumnDefinition x:Name="ColT2Damage" Width="1*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#6366F1" CornerRadius="5,0,0,5"/>
                                            <Border Grid.Column="1" Background="#EF4444" CornerRadius="0,5,5,0"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Creep Score comparison -->
                                    <StackPanel Margin="0,0,0,25">
                                        <Grid Margin="0,0,0,5">
                                            <TextBlock x:Name="TxtT1CS" Text="0 CS" Foreground="#6366F1" FontWeight="Bold" FontSize="12"/>
                                            <TextBlock Text="Chỉ số lính (CS)" Foreground="#9CA3AF" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="TxtT2CS" Text="0 CS" Foreground="#EF4444" FontWeight="Bold" FontSize="12" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <Grid Height="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition x:Name="ColT1CS" Width="1*"/>
                                                <ColumnDefinition x:Name="ColT2CS" Width="1*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#6366F1" CornerRadius="5,0,0,5"/>
                                            <Border Grid.Column="1" Background="#EF4444" CornerRadius="0,5,5,0"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Dragons Killed comparison -->
                                    <StackPanel Margin="0,0,0,25">
                                        <Grid Margin="0,0,0,5">
                                            <TextBlock x:Name="TxtT1Dragons" Text="0 Rồng" Foreground="#6366F1" FontWeight="Bold" FontSize="12"/>
                                            <TextBlock Text="🐲 Số rồng đã tiêu diệt" Foreground="#9CA3AF" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="TxtT2Dragons" Text="0 Rồng" Foreground="#EF4444" FontWeight="Bold" FontSize="12" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <Grid Height="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition x:Name="ColT1Dragons" Width="1*"/>
                                                <ColumnDefinition x:Name="ColT2Dragons" Width="1*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#6366F1" CornerRadius="5,0,0,5"/>
                                            <Border Grid.Column="1" Background="#EF4444" CornerRadius="0,5,5,0"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Towers Destroyed comparison -->
                                    <StackPanel Margin="0,0,0,0">
                                        <Grid Margin="0,0,0,5">
                                            <TextBlock x:Name="TxtT1Towers" Text="0 Trụ" Foreground="#6366F1" FontWeight="Bold" FontSize="12"/>
                                            <TextBlock Text="🗼 Số trụ ăn được" Foreground="#9CA3AF" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="TxtT2Towers" Text="0 Trụ" Foreground="#EF4444" FontWeight="Bold" FontSize="12" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <Grid Height="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition x:Name="ColT1Towers" Width="1*"/>
                                                <ColumnDefinition x:Name="ColT2Towers" Width="1*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#6366F1" CornerRadius="5,0,0,5"/>
                                            <Border Grid.Column="1" Background="#EF4444" CornerRadius="0,5,5,0"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>

            <!-- Footer Close Button -->
            <Grid Grid.Row="3" Margin="0,5,0,0">
                <Button Content="Đóng" Width="90" Height="36" Background="#1E293B" Foreground="#9CA3AF" BorderBrush="#334155" Cursor="Hand" Click="CloseButton_Click" HorizontalAlignment="Right">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#334155"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
