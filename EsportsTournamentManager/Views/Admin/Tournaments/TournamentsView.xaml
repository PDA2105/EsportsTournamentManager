<UserControl x:Class="EsportsTournamentManager.Views.Admin.Tournaments.TournamentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EsportsTournamentManager.Views.Admin.Tournaments"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="1000">

    <UserControl.Resources>
        <!-- Custom Input Box Style -->
        <Style x:Key="SearchTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#6366F1"/>
                                <Setter TargetName="border" Property="Background" Value="#0F172A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium DataGrid Style (using transparent borders) -->
        <Style x:Key="PremiumDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RowBackground" Value="#0F172A"/>
            <Setter Property="AlternatingRowBackground" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HorizontalGridLinesBrush" Value="Transparent"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1E293B"/>
                        <Setter Property="Foreground" Value="#9CA3AF"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#334155"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="12,0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#312E81"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#312E81"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- ============================================== -->
        <!-- PANEL A: TOURNAMENTS LIST SECTION              -->
        <!-- ============================================== -->
        <Grid x:Name="PanelTournaments" Visibility="Visible">
            <Border Background="#111827" CornerRadius="12" BorderBrush="#1E293B" BorderThickness="1" Padding="25">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="Auto"/> <!-- Toolbar -->
                        <RowDefinition Height="*"/>    <!-- DataGrid -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="QUẢN LÝ GIẢI ĐẤU" Foreground="#F9FAFB" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                    <Grid Grid.Row="1" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="TxtSearchTournament" Grid.Column="0" Style="{StaticResource SearchTextBox}" Tag="Tìm kiếm giải đấu..." TextChanged="TxtSearchTournament_TextChanged" VerticalAlignment="Center"/>
                        
                        <Button Grid.Column="2" Content="+ Tạo Giải Đấu" Style="{StaticResource ActionButton}" Background="#6366F1" Foreground="#FFFFFF" Click="BtnAddTournament_Click" Padding="15,0" Height="34" FontWeight="SemiBold"/>
                    </Grid>

                    <DataGrid x:Name="GridTournaments" Grid.Row="2" Style="{StaticResource PremiumDataGrid}" SelectionChanged="GridTournaments_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tên Giải Đấu" Binding="{Binding Name}" Width="3*"/>
                            <DataGridTextColumn Header="Bộ Môn" Binding="{Binding GameType}" Width="1.5*"/>
                            <DataGridTextColumn Header="Thể Thức" Binding="{Binding Format}" Width="2*"/>
                            <DataGridTextColumn Header="Số Đội Tối Đa" Binding="{Binding MaxTeams}" Width="1.5*"/>
                            <DataGridTextColumn Header="Ngày Bắt Đầu" Binding="{Binding StartDate, StringFormat=\{0:dd/MM/yyyy\}}" Width="2*"/>
                            
                            <DataGridTemplateColumn Header="Trạng Thái" Width="2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="10,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                            <Setter Property="Background" Value="#374151"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Active">
                                                            <Setter Property="Background" Value="#1E1B4B"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                            <Setter Property="Background" Value="#064E3B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}" Foreground="#FFFFFF" FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                <Setter Property="Text" Value="Chờ bắt đầu"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Active">
                                                                <Setter Property="Text" Value="Đang diễn ra"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                <Setter Property="Text" Value="Đã kết thúc"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Actions -->
                            <DataGridTemplateColumn Header="Thao Tác" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="Xem Chi Tiết" Background="Transparent" Foreground="#06B6D4" Cursor="Hand" Click="BtnViewDetail_Click" Margin="0,0,15,0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontWeight="Bold"/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Foreground" Value="#22D3EE"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <Button Content="Sửa" Background="Transparent" Foreground="#6366F1" Cursor="Hand" Click="BtnEditTournament_Click" Margin="0,0,15,0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontWeight="SemiBold"/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Foreground" Value="#818CF8"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <Button Content="Xóa" Background="Transparent" Foreground="#EF4444" Cursor="Hand" Click="BtnDeleteTournament_Click">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontWeight="SemiBold"/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Foreground" Value="#F87171"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- ============================================== -->
        <!-- PANEL B: TOURNAMENT OVERVIEW                   -->
        <!-- ============================================== -->
        <Grid x:Name="PanelTournamentOverview" Visibility="Collapsed">
            <Border Background="#111827" CornerRadius="12" BorderBrush="#1E293B" BorderThickness="1" Padding="25">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header (Back + Title) -->
                        <RowDefinition Height="*"/>    <!-- Content Area (Split Left Info & Right Teams List) -->
                    </Grid.RowDefinitions>

                    <!-- Header Title and Back Button -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="← Quay lại Danh sách" Background="Transparent" Foreground="#9CA3AF" Cursor="Hand" Click="BtnBackToTournaments_Click" Margin="0,0,20,0" VerticalAlignment="Center">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="14" FontWeight="SemiBold"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#F9FAFB"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <TextBlock x:Name="TxtTournamentDetailHeader" Grid.Column="1" Text="TỔNG QUAN GIẢI ĐẤU - [TÊN]" Foreground="#F9FAFB" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Split Detail Grid -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Info and Config Sidebar -->
                        <Border Grid.Column="0" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,20,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Properties list -->
                                    <RowDefinition Height="*"/>    <!-- Actions area -->
                                </Grid.RowDefinitions>

                                <!-- Properties List -->
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="THÔNG TIN CHI TIẾT" Foreground="#9CA3AF" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>
                                    
                                    <TextBlock Text="Bộ môn:" Foreground="#6B7280" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="TxtInfoGameType" Text="LoL" Foreground="#F9FAFB" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>

                                    <TextBlock Text="Thể thức:" Foreground="#6B7280" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="TxtInfoFormat" Text="Single Elimination" Foreground="#F9FAFB" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>

                                    <TextBlock Text="Số đội tuyển:" Foreground="#6B7280" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="TxtInfoMaxTeams" Text="8 Đội tối đa" Foreground="#F9FAFB" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>

                                    <TextBlock Text="Trạng thái:" Foreground="#6B7280" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="TxtInfoStatus" Text="Chờ bắt đầu" Foreground="#38BDF8" FontSize="15" FontWeight="Bold" Margin="0,0,0,15"/>

                                    <Border BorderBrush="#1E293B" BorderThickness="0,0,0,1" Margin="0,0,0,15"/>

                                    <!-- MVP Section -->
                                    <TextBlock Text="MVP GIẢI ĐẤU" Foreground="#9CA3AF" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <Border x:Name="PanelTournamentMvp" Background="#1E1B4B" BorderBrush="#4F46E5" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,15" Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock x:Name="TxtMvpName" Text="Faker" Foreground="#F9FAFB" FontSize="15" FontWeight="Black"/>
                                            <TextBlock x:Name="TxtMvpTeam" Text="T1 Esports" Foreground="#818CF8" FontSize="12" FontWeight="SemiBold" Margin="0,2,0,4"/>
                                            <TextBlock x:Name="TxtMvpScore" Text="Điểm TB: 24.5" Foreground="#10B981" FontSize="12" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock x:Name="TxtMvpNotDecided" Text="Chưa có thống kê" Foreground="#6B7280" FontSize="13" FontStyle="Italic" Margin="0,0,0,15"/>
                                </StackPanel>

                                <!-- Actions Area -->
                                <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
                                    <!-- Start Button (Only for Pending) -->
                                    <Button x:Name="BtnStartTournament" Content="Bắt đầu Giải đấu" Style="{StaticResource ActionButton}" Background="#10B981" Foreground="#FFFFFF" Click="BtnStartTournament_Click" Height="40" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>
                                    
                                    <!-- View Bracket & Results Button -->
                                    <Button x:Name="BtnViewBracket" Content="Xem Nhánh &amp; Kết Quả" Style="{StaticResource ActionButton}" Background="#6366F1" Foreground="#FFFFFF" Click="BtnViewBracket_Click" Height="40" FontSize="13" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Right Teams List / Selection -->
                        <Border Grid.Column="1" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="TxtDynamicListHeader" Grid.Row="0" Text="ĐỘI TUYỂN THAM GIA" Foreground="#9CA3AF" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>
                                
                                <!-- Pending: Checked list of all Teams -->
                                <ListView x:Name="ListSelectTeams" Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="#F9FAFB" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding TeamName}" Tag="{Binding TeamId}" IsChecked="{Binding IsAssigned}" Foreground="#F9FAFB" Margin="0,5" Checked="TeamCheckBox_Changed" Unchecked="TeamCheckBox_Changed" VerticalContentAlignment="Center" FontSize="13"/>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <!-- Active/Completed: Simple List of assigned Teams -->
                                <ListView x:Name="ListShowTeams" Grid.Row="1" Visibility="Collapsed" Background="Transparent" BorderThickness="0" Foreground="#F9FAFB" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,8">
                                                <Ellipse Width="8" Height="8" Fill="#6366F1" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding TeamName}" Foreground="#F9FAFB" FontSize="13.5" FontWeight="Medium" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ============================================== -->
        <!-- PANEL C: TOURNAMENT BRACKET & MATCHES          -->
        <!-- ============================================== -->
        <Grid x:Name="PanelTournamentBracket" Visibility="Collapsed">
            <Border Background="#111827" CornerRadius="12" BorderBrush="#1E293B" BorderThickness="1" Padding="25">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header (Back + Title) -->
                        <RowDefinition Height="*"/>    <!-- Content Area (Full Bracket Visual) -->
                    </Grid.RowDefinitions>

                    <!-- Header Title and Back Button -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="← Quay lại Tổng quan" Background="Transparent" Foreground="#9CA3AF" Cursor="Hand" Click="BtnBackToOverview_Click" Margin="0,0,20,0" VerticalAlignment="Center">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="14" FontWeight="SemiBold"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#F9FAFB"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <TextBlock x:Name="TxtTournamentBracketHeader" Grid.Column="1" Text="NHÁNH ĐẤU &amp; KẾT QUẢ - [TÊN]" Foreground="#F9FAFB" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Bracket View Area -->
                    <Border Grid.Row="1" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="15">
                        <Grid>
                            <!-- Bracket Container -->
                            <ScrollViewer x:Name="ScrollBracket" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <Grid>
                                    <!-- Single Elimination: Dynamic Canvas -->
                                    <Canvas x:Name="CanvasBracket" Width="1200" Height="600" Background="Transparent" Visibility="Visible"/>
                                    
                                    <!-- Round Robin: List of matches grouped by rounds -->
                                    <ScrollViewer x:Name="ScrollRoundRobin" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="PanelRoundRobin" Margin="10"/>
                                    </ScrollViewer>
                                </Grid>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
