<UserControl x:Class="EsportsTournamentManager.Views.Admin.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EsportsTournamentManager.Views.Admin.Dashboard"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- Dashboard DataGrid Style -->
        <Style x:Key="DashboardDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RowBackground" Value="#111827"/>
            <Setter Property="AlternatingRowBackground" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeight" Value="32"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#0F172A"/>
                        <Setter Property="Foreground" Value="#9CA3AF"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#334155"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="8,0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter SnapsToDevicePixels="True"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Welcome Header -->
            <RowDefinition Height="Auto"/> <!-- Overview Cards -->
            <RowDefinition Height="*"/>    <!-- Detail Tables -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Chào mừng quay trở lại hệ thống!" Foreground="#F9FAFB" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Overview Cards -->
        <UniformGrid Grid.Row="1" Columns="3" VerticalAlignment="Top" Rows="1" Margin="0,0,0,20">
            <!-- Card 1: Teams -->
            <Border Background="#1E293B" CornerRadius="5" Margin="0,0,15,0" Padding="20" Height="140">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Đội tuyển" Foreground="#9CA3AF" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtStatsTeams" Text="--" Foreground="#F9FAFB" FontSize="36" FontWeight="Black" Margin="0,10,0,0"/>
                    <TextBlock Text="đã đăng ký trong hệ thống" Foreground="#9CA3AF" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 2: Players -->
            <Border Background="#1E293B" CornerRadius="5" Margin="0,0,15,0" Padding="20" Height="140">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Tuyển thủ" Foreground="#9CA3AF" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtStatsPlayers" Text="--" Foreground="#F9FAFB" FontSize="36" FontWeight="Black" Margin="0,10,0,0"/>
                    <TextBlock Text="hồ sơ thi đấu chính thức" Foreground="#9CA3AF" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 3: Tournaments -->
            <Border Background="#1E293B" CornerRadius="5" Padding="20" Height="140">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Giải đấu" Foreground="#9CA3AF" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtStatsTournaments" Text="--" Foreground="#F9FAFB" FontSize="36" FontWeight="Black" Margin="0,10,0,0"/>
                    <TextBlock Text="đang diễn ra hoặc đã kết thúc" Foreground="#9CA3AF" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Detail Tables Grid -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <!-- Column 0: Active Tournaments -->
            <Border Grid.Column="0" Background="#1E293B" CornerRadius="5" Margin="0,0,10,0" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Giải đấu đang diễn ra" Foreground="#F9FAFB" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <DataGrid x:Name="GridActiveTournaments" Grid.Row="1" Style="{StaticResource DashboardDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tên giải đấu" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Bộ môn" Binding="{Binding GameType}" Width="70" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Thể thức" Binding="{Binding FormatDisplay}" Width="170" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Tiến độ" Binding="{Binding ProgressText}" Width="75" IsReadOnly="True" FontWeight="Bold"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Column 1: Top 5 Performers -->
            <Border Grid.Column="1" Background="#1E293B" CornerRadius="5" Margin="10,0,0,0" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Top 5 Tuyển thủ xuất sắc" Foreground="#F9FAFB" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <DataGrid x:Name="GridTopPlayers" Grid.Row="1" Style="{StaticResource DashboardDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Hạng" Binding="{Binding Rank}" Width="40" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Tuyển thủ" Binding="{Binding InGameName}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Đội tuyển" Binding="{Binding TeamName}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Điểm TB" Binding="{Binding DisplayPTS}" Width="75" IsReadOnly="True" FontWeight="Bold"/>
                            <DataGridTextColumn Header="Số trận" Binding="{Binding DisplayMatches}" Width="65" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
