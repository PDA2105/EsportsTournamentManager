<Window x:Class="EsportsTournamentManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EsportsTournamentManager"
        xmlns:localviews="clr-namespace:EsportsTournamentManager.Views"
        mc:Ignorable="d"
        Title="Esports Tournament Manager" 
        Height="650" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- Color Palette -->
        <SolidColorBrush x:Key="BackgroundDark" Color="#0B0F19"/>
        <SolidColorBrush x:Key="BackgroundForm" Color="#0F172A"/>
        <SolidColorBrush x:Key="SidebarBg" Color="#111827"/>
        <SolidColorBrush x:Key="HeaderBg" Color="#1F2937"/>
        <SolidColorBrush x:Key="PrimaryColor" Color="#6366F1"/>
        <SolidColorBrush x:Key="PrimaryHover" Color="#4F46E5"/>
        <SolidColorBrush x:Key="AccentColor" Color="#06B6D4"/>
        <SolidColorBrush x:Key="TextLight" Color="#F9FAFB"/>
        <SolidColorBrush x:Key="TextMuted" Color="#9CA3AF"/>
        <SolidColorBrush x:Key="BorderColor" Color="#1E293B"/>

        <!-- Shadows -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="25" ShadowDepth="0" Color="#000000" Opacity="0.6"/>
        <DropShadowEffect x:Key="ButtonShadow" BlurRadius="8" ShadowDepth="2" Color="#6366F1" Opacity="0.4"/>

        <!-- Custom Input Box Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#6366F1"/>
                                <Setter TargetName="border" Property="Background" Value="#1E1B4B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#6366F1"/>
                                <Setter TargetName="border" Property="Background" Value="#1E1B4B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Button Style -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="10,4,10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="15,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1F2937"/>
                                <Setter Property="Foreground" Value="#F9FAFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Active Sidebar Button Style -->
        <Style x:Key="ActiveSidebarButton" TargetType="Button" BasedOn="{StaticResource SidebarButton}">
            <Setter Property="Background" Value="#6366F1"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="15,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" Background="#0F172A" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Effect="{StaticResource CardShadow}">
        <Grid>
            <!-- ========================================== -->
            <!-- 1. LOGIN GRID PANEL (Visible by Default)   -->
            <!-- ========================================== -->
            <Grid x:Name="LoginGrid" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*"/>
                    <ColumnDefinition Width="5*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Branding Panel -->
                <Border CornerRadius="15,0,0,15" Grid.Column="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#4F46E5" Offset="0.0"/>
                            <GradientStop Color="#06B6D4" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <!-- Graphics background details -->
                        <Canvas Opacity="0.12">
                            <Ellipse Fill="#FFFFFF" Width="250" Height="250" Canvas.Left="-50" Canvas.Top="-50"/>
                            <Ellipse Fill="#FFFFFF" Width="300" Height="300" Canvas.Left="150" Canvas.Top="350"/>
                            <Path Fill="#FFFFFF" Data="M 0,0 L 400,0 L 400,400 Z" Canvas.Left="50" Canvas.Top="100"/>
                        </Canvas>

                        <StackPanel VerticalAlignment="Center" Margin="30">
                            <Border Width="80" Height="80" Background="#FFFFFF" CornerRadius="22" HorizontalAlignment="Center" Margin="0,0,0,20">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.3"/>
                                </Border.Effect>
                                <Grid>
                                    <Path Fill="#4F46E5" Data="M20,15 L60,15 L55,40 C50,55 30,55 25,40 Z M28,55 L52,55 L40,65 Z" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="ESPORTS" Foreground="#FFFFFF" FontSize="32" FontWeight="Black" TextAlignment="Center"/>
                            <TextBlock Text="TOURNAMENT MANAGER" Foreground="#E0E7FF" FontSize="13" FontWeight="SemiBold" TextAlignment="Center" Margin="0,5,0,25"/>
                            <TextBlock Text="Hệ thống quản lý, sắp xếp nhánh đấu và điều hành giải đấu chuyên nghiệp." Foreground="#F3F4F6" FontSize="13" TextWrapping="Wrap" TextAlignment="Center" LineHeight="20" Opacity="0.9"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Right Form Panel -->
                <Border Grid.Column="1" Background="#0F172A" CornerRadius="0,15,15,0" Padding="50,40">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Window Controls -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="0">
                            <Button Content="✕" Background="Transparent" BorderBrush="Transparent" Foreground="{StaticResource TextMuted}" FontSize="18" Cursor="Hand" Click="CloseButton_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#EF4444"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <!-- Login Inputs Form -->
                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="Đăng Nhập" Foreground="{StaticResource TextLight}" FontSize="28" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBlock Text="Đăng nhập tài khoản Ban tổ chức hoặc Trọng tài" Foreground="{StaticResource TextMuted}" FontSize="14" Margin="0,0,0,30"/>

                            <TextBlock Text="Tên đăng nhập" Foreground="{StaticResource TextLight}" FontSize="13" FontWeight="Medium" Margin="0,0,0,8"/>
                            <TextBox x:Name="TxtUsername" Style="{StaticResource ModernTextBox}" Margin="0,0,0,20"/>

                            <TextBlock Text="Mật khẩu" Foreground="{StaticResource TextLight}" FontSize="13" FontWeight="Medium" Margin="0,0,0,8"/>
                            <PasswordBox x:Name="TxtPassword" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,12"/>

                            <!-- Error Alert Label -->
                            <TextBlock x:Name="LblLoginError" Foreground="#EF4444" FontSize="13" TextWrapping="Wrap" Margin="0,5,0,15" Visibility="Collapsed"/>

                            <!-- Login Action Button -->
                            <Button Content="Đăng Nhập" Height="45" FontSize="15" FontWeight="Bold" Foreground="#FFFFFF" Cursor="Hand" Click="LoginButton_Click" Margin="0,10,0,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#6366F1"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Effect="{StaticResource ButtonShadow}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#4F46E5"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <!-- Bottom Notice -->
                        <TextBlock Text="Tài khoản mặc định: admin / admin123 | referee / referee123" Foreground="{StaticResource TextMuted}" FontSize="11" TextAlignment="Center" Grid.Row="2" Opacity="0.7"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ========================================== -->
            <!-- 2. MAIN APPLICATION WORKSPACE GRID         -->
            <!-- ========================================== -->
            <Grid x:Name="MainGrid" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <!-- Sidebar -->
                    <ColumnDefinition Width="*"/>
                    <!-- Workspace -->
                </Grid.ColumnDefinitions>

                <!-- Left Sidebar -->
                <Border Grid.Column="0" Background="{StaticResource SidebarBg}" CornerRadius="15,0,0,15" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="80"/>
                            <!-- Logo Area -->
                            <RowDefinition Height="*"/>
                            <!-- Navigation Menu -->
                            <RowDefinition Height="Auto"/>
                            <!-- Active User Profile & Logout -->
                        </Grid.RowDefinitions>

                        <!-- Header Branding -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                            <Border Width="36" Height="36" Background="#6366F1" CornerRadius="10">
                                <Path Fill="#FFFFFF" Data="M8,6 L28,6 L25,18 C22,25 14,25 11,18 Z" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" Margin="6"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0">
                                <TextBlock Text="ESPORTS" Foreground="{StaticResource TextLight}" FontSize="16" FontWeight="Black"/>
                                <TextBlock Text="MANAGER" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Navigation Sidebar Menu -->
                        <StackPanel Grid.Row="1" Margin="0,20,0,0">
                            <Button x:Name="BtnMenuDashboard" Style="{StaticResource ActiveSidebarButton}" Click="MenuButton_Click" Tag="Dashboard">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⌂" FontSize="18" Margin="0,0,10,0" FontWeight="Bold"/>
                                    <TextBlock Text="Bảng điều khiển" FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnMenuTeams" Style="{StaticResource SidebarButton}" Click="MenuButton_Click" Tag="Teams">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👥" FontSize="16" Margin="0,0,10,0"/>
                                    <TextBlock Text="Đội tuyển &amp; Tuyển thủ" FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnMenuTournaments" Style="{StaticResource SidebarButton}" Click="MenuButton_Click" Tag="Tournaments">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏆" FontSize="16" Margin="0,0,10,0"/>
                                    <TextBlock Text="Giải đấu &amp; Lịch đấu" FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Footer Active User profile & Logout -->
                        <Border Grid.Row="2" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock x:Name="TxtHeaderUserName" Text="Admin Name" Foreground="{StaticResource TextLight}" FontSize="14" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="TxtHeaderUserRole" Text="Quản trị viên" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                                </StackPanel>

                                <Button Grid.Column="1" Content="➔" Background="Transparent" BorderBrush="Transparent" Foreground="#EF4444" FontSize="18" FontWeight="Bold" Cursor="Hand" Click="LogoutButton_Click" ToolTip="Đăng xuất">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="Transparent">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="#F87171"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Right Content Workspace -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="80"/>
                        <!-- Top Header -->
                        <RowDefinition Height="*"/>
                        <!-- Central Content Frame -->
                    </Grid.RowDefinitions>

                    <!-- Top Header Bar -->
                    <Border Grid.Row="0" Background="{StaticResource HeaderBg}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="30,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Section Title -->
                            <TextBlock x:Name="TxtHeaderTitle" Text="Bảng điều khiển" Foreground="{StaticResource TextLight}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>

                            <!-- Close Window button -->
                            <Button Grid.Column="1" Content="✕" Background="Transparent" BorderBrush="Transparent" Foreground="{StaticResource TextMuted}" FontSize="18" Cursor="Hand" Click="CloseButton_Click" VerticalAlignment="Center">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#EF4444"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Central View switching area -->
                    <Grid Grid.Row="1" Margin="30">
                        <localviews:DashboardView x:Name="DashboardSection" Visibility="Visible"/>
                        <localviews:TeamsView x:Name="TeamsSection" Visibility="Collapsed"/>
                        <localviews:TournamentsView x:Name="TournamentsSection" Visibility="Collapsed"/>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
